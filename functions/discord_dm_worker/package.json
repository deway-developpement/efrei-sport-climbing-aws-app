{
    "name": "discord_dm_worker",
    "version": "1.0.0",
    "description": "Persistent Discord DM worker backed by Algolia Agent Studio",
    "main": "dist/app.js",
    "author": "Codex",
    "license": "MIT",
    "scripts": {
        "build": "esbuild src/app.ts --bundle --platform=node --target=node22 --outfile=dist/app.js",
        "start": "node --env-file-if-exists=.env.local dist/app.js",
        "dev": "node --env-file-if-exists=.env.local --import tsx src/app.ts",
        "backfill:announcements": "node --env-file-if-exists=.env.local --import tsx scripts/backfill.association.announcements.ts",
        "unit": "jest",
        "lint": "eslint '*.ts' 'src/**/*.ts' 'tests/unit/**/*.ts' --quiet --fix",
        "compile": "tsc",
        "test": "npm run compile && npm run unit"
    },
    "dependencies": {
        "@aws-sdk/client-dynamodb": "^3.281.0",
        "@aws-sdk/client-secrets-manager": "^3.282.0",
        "discord.js": "^14.22.1"
    },
    "devDependencies": {
        "@types/jest": "^29.4.0",
        "@types/node": "^22.15.29",
        "@typescript-eslint/eslint-plugin": "^5.10.2",
        "@typescript-eslint/parser": "^5.10.2",
        "esbuild": "^0.25.1",
        "esbuild-jest": "^0.5.0",
        "eslint": "^8.8.0",
        "eslint-config-prettier": "^8.3.0",
        "eslint-plugin-prettier": "^4.0.0",
        "jest": "^29.2.1",
        "prettier": "^2.5.1",
        "tsx": "^4.20.5",
        "typescript": "^5.8.3"
    }
}
